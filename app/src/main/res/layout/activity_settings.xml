<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#111111">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Indietro"
            android:textColor="#FFFFFF"
            android:backgroundTint="#333333"
            android:textSize="13sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Impostazioni"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:gravity="center" />

        <View android:layout_width="80dp" android:layout_height="1dp" />
    </LinearLayout>

    <!-- Contenuto scrollabile -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ===== SEZIONE MACRODROID ===== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MACRODROID"
                android:textColor="#888888"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etMacroPackage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Pacchetto (es. com.arlosoft.macrodroid)"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:background="#1A1A1A"
                android:padding="12dp"
                android:textSize="13sp"
                android:layout_marginBottom="8dp"
                android:inputType="text" />

            <EditText
                android:id="@+id/etMacroName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nome macro (es. WebViewerBolla)"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:background="#1A1A1A"
                android:padding="12dp"
                android:textSize="13sp"
                android:layout_marginBottom="8dp"
                android:inputType="text" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <Button
                    android:id="@+id/btnTestMacroStart"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="▶ Test avvio"
                    android:textColor="#000000"
                    android:backgroundTint="#FFFFFF"
                    android:textSize="12sp"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btnTestMacroStop"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="⏹ Test stop"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#333333"
                    android:textSize="12sp"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnSaveMacro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Salva impostazioni MacroDroid"
                android:textColor="#000000"
                android:backgroundTint="#FFFFFF"
                android:textSize="13sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp" />

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#1F1F1F" android:layout_marginBottom="16dp" />

            <!-- ===== SEZIONE PROGETTI ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="PROGETTI"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:letterSpacing="0.15" />

                <Button
                    android:id="@+id/btnAddProject"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+ Aggiungi"
                    android:textColor="#000000"
                    android:backgroundTint="#FFFFFF"
                    android:textSize="12sp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvNoProjects"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nessun progetto. Aggiungi il primo."
                android:textColor="#555555"
                android:textSize="13sp"
                android:gravity="center"
                android:padding="24dp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvProjects"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="16dp" />

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#1F1F1F" android:layout_marginBottom="16dp" />

            <!-- ===== SEZIONE SISTEMA ===== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SISTEMA"
                android:textColor="#888888"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnClearCache"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Svuota cache"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1A1A1A"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />

            <Button
                android:id="@+id/btnResetCookies"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Reset cookie"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1A1A1A"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />

            <Button
                android:id="@+id/btnExportBackup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Esporta configurazione (JSON)"
                android:textColor="#000000"
                android:backgroundTint="#FFFFFF"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />

            <Button
                android:id="@+id/btnImportBackup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Importa configurazione (JSON)"
                android:textColor="#FFFFFF"
                android:backgroundTint="#333333"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />

            <Button
                android:id="@+id/btnResetApp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Reset dati app"
                android:textColor="#FFFFFF"
                android:backgroundTint="#3D0000"
                android:textSize="13sp"
                android:layout_marginBottom="16dp" />

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#1F1F1F" android:layout_marginBottom="16dp" />

            <!-- ===== SEZIONE INFORMAZIONI ===== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="INFORMAZIONI"
                android:textColor="#888888"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvVersionApp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Versione app: —"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvVersionAndroid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Android: —"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvDevice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dispositivo: —"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnDiagnostics"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mostra diagnostica"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1A1A1A"
                android:textSize="13sp"
                android:layout_marginBottom="32dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
